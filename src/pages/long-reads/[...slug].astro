---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('long-reads');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'long-reads'>;
}

const { post } = Astro.props;
const { Content } = await post.render();

const allPosts = (await getCollection('long-reads', ({ data }) => data.status === 'published'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const currentIndex = allPosts.findIndex((p) => p.slug === post.slug);
const prevPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${post.data.title} - dk.ai`} description={post.data.excerpt}>
  <!-- Reading Progress Bar -->
  <div class="reading-progress" id="reading-progress"></div>

  <article class="max-w-reading mx-auto">
    <!-- Header -->
    <header class="mb-10">
      <div class="flex items-center gap-2 mb-4">
        <span class="badge badge-long-reads">Long Read</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4 leading-tight">
        {post.data.title}
      </h1>
      <div class="flex items-center gap-4 text-sm text-surface-200/80 font-mono">
        <span class="inline-flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
        </span>
        {post.data.readingTime && (
          <span class="inline-flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {post.data.readingTime} min read
          </span>
        )}
      </div>
    </header>

    <!-- Hero Image -->
    {post.data.heroImage && (
      <figure class="mb-10 -mx-4 sm:mx-0">
        <div class="rounded-none sm:rounded-xl overflow-hidden">
          <img
            src={post.data.heroImage}
            alt={post.data.title}
            class="w-full h-64 sm:h-80 object-cover"
            loading="eager"
          />
        </div>
        {post.data.heroCredit && (
          <figcaption class="mt-3 text-xs font-mono px-4 sm:px-0" style="color: var(--text-faint);">
            {post.data.heroCreditUrl ? (
              <a href={post.data.heroCreditUrl} target="_blank" rel="noopener noreferrer" class="hover:text-blue-400 transition-colors">
                {post.data.heroCredit}
              </a>
            ) : (
              post.data.heroCredit
            )}
          </figcaption>
        )}
      </figure>
    )}

    <!-- Content -->
    <div class="prose prose-invert prose-lg max-w-none">
      <Content />
    </div>

    <!-- Related Lab -->
    {post.data.relatedLab && (
      <div class="glass p-5 mt-10">
        <span class="badge badge-lab mb-2">Related Experiment</span>
        <a href={`/lab/${post.data.relatedLab}`} class="text-accent-DEFAULT hover:text-accent-hover transition-colors text-sm">
          View the related Lab experiment &rarr;
        </a>
      </div>
    )}

    <!-- Prev/Next Navigation -->
    <nav class="flex flex-col sm:flex-row gap-4 mt-12 pt-8 border-t border-white/5">
      {prevPost && (
        <a href={`/long-reads/${prevPost.slug}`} class="glass p-4 flex-1 group">
          <span class="text-xs text-surface-200/70 font-mono">&larr; Previous</span>
          <p class="text-sm font-medium text-white group-hover:text-accent-DEFAULT transition-colors mt-1">
            {prevPost.data.title}
          </p>
        </a>
      )}
      {nextPost && (
        <a href={`/long-reads/${nextPost.slug}`} class="glass p-4 flex-1 text-right group">
          <span class="text-xs text-surface-200/70 font-mono">Next &rarr;</span>
          <p class="text-sm font-medium text-white group-hover:text-accent-DEFAULT transition-colors mt-1">
            {nextPost.data.title}
          </p>
        </a>
      )}
    </nav>
  </article>

  <script is:inline>
    // Reading progress bar
    function updateProgress() {
      const article = document.querySelector('article');
      if (!article) return;
      const rect = article.getBoundingClientRect();
      const progress = Math.min(
        Math.max((-rect.top) / (rect.height - window.innerHeight), 0),
        1
      );
      const bar = document.getElementById('reading-progress');
      if (bar) bar.style.width = `${progress * 100}%`;
    }
    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();
  </script>

  <!-- Highlight-to-share popup -->
  <div id="share-popup" style="display:none; position:absolute; z-index:50;">
    <div style="display:flex; gap:2px; padding:4px; border-radius:10px; background:var(--bg-card); border:1px solid var(--border-color); backdrop-filter:blur(20px); box-shadow:0 4px 20px rgba(0,0,0,0.3);">
      <button data-share="twitter" title="Share on X" style="display:flex; align-items:center; justify-content:center; width:36px; height:36px; border-radius:8px; border:none; background:transparent; cursor:pointer; color:var(--text-secondary); transition:all 0.15s;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </button>
      <button data-share="linkedin" title="Share on LinkedIn" style="display:flex; align-items:center; justify-content:center; width:36px; height:36px; border-radius:8px; border:none; background:transparent; cursor:pointer; color:var(--text-secondary); transition:all 0.15s;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </button>
      <button data-share="copy" title="Copy quote" style="display:flex; align-items:center; justify-content:center; width:36px; height:36px; border-radius:8px; border:none; background:transparent; cursor:pointer; color:var(--text-secondary); transition:all 0.15s;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
      </button>
    </div>
  </div>

  <script is:inline>
    (function() {
      const popup = document.getElementById('share-popup');
      const article = document.querySelector('.prose');
      if (!popup || !article) return;

      let selectedText = '';
      const pageUrl = window.location.href;

      function showPopup(x, y) {
        popup.style.display = 'block';
        const rect = popup.getBoundingClientRect();
        const left = Math.min(Math.max(x - rect.width / 2, 8), window.innerWidth - rect.width - 8);
        const top = y - rect.height - 10 + window.scrollY;
        popup.style.left = left + 'px';
        popup.style.top = top + 'px';
      }

      function hidePopup() {
        popup.style.display = 'none';
      }

      article.addEventListener('mouseup', function(e) {
        // Small delay so selection is finalized
        setTimeout(function() {
          const sel = window.getSelection();
          const text = sel ? sel.toString().trim() : '';
          if (text.length > 5 && text.length < 500) {
            selectedText = text;
            const range = sel.getRangeAt(0);
            const rect = range.getBoundingClientRect();
            showPopup(rect.left + rect.width / 2, rect.top);
          } else {
            hidePopup();
          }
        }, 10);
      });

      // Hide on click outside or scroll
      document.addEventListener('mousedown', function(e) {
        if (!popup.contains(e.target)) hidePopup();
      });

      // Handle share buttons
      popup.addEventListener('click', function(e) {
        const btn = e.target.closest('[data-share]');
        if (!btn) return;

        const action = btn.dataset.share;
        const quote = '"' + selectedText + '"';

        if (action === 'twitter') {
          const url = 'https://twitter.com/intent/tweet?text=' +
            encodeURIComponent(quote) + '&url=' + encodeURIComponent(pageUrl);
          window.open(url, '_blank', 'width=550,height=420');
        } else if (action === 'linkedin') {
          const url = 'https://www.linkedin.com/sharing/share-offsite/?url=' + encodeURIComponent(pageUrl);
          window.open(url, '_blank', 'width=550,height=520');
        } else if (action === 'copy') {
          navigator.clipboard.writeText(quote + ' ' + pageUrl).then(function() {
            btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
            btn.style.color = '#10b981';
            setTimeout(function() {
              btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>';
              btn.style.color = '';
            }, 1500);
          });
        }

        hidePopup();
      });

      // Hover effect on buttons
      popup.querySelectorAll('button').forEach(function(btn) {
        btn.addEventListener('mouseenter', function() { btn.style.background = 'var(--bg-card-hover)'; btn.style.color = 'var(--text-primary)'; });
        btn.addEventListener('mouseleave', function() { btn.style.background = 'transparent'; btn.style.color = 'var(--text-secondary)'; });
      });
    })();
  </script>
</BaseLayout>
