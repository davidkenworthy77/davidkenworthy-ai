---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Connect - dk.ai" description="Let's talk. I'm on LinkedIn, Instagram, or drop me a message directly.">
  <div class="max-w-4xl mx-auto">
    <div class="mb-10">
      <h1 class="text-3xl font-bold text-white mb-2">Connect</h1>
      <p class="text-lg text-surface-200">Let's talk. Reach out however works for you.</p>
    </div>

    <!-- Social Links -->
    <div class="grid md:grid-cols-2 gap-4 mb-10">
      <a
        href="https://www.linkedin.com/in/david-kenworthy-a6612250/"
        target="_blank"
        rel="noopener noreferrer"
        class="glass card-hover flex items-center gap-4 p-5 group"
      >
        <div class="w-10 h-10 rounded-lg bg-blue-600/20 border border-blue-600/30 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-blue-400" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-white group-hover:text-blue-400 transition-colors">LinkedIn</p>
          <p class="text-xs text-surface-200/70">David Kenworthy</p>
        </div>
        <svg class="w-4 h-4 text-surface-200/50 group-hover:text-surface-200/80 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>

      <a
        href="https://instagram.com/davidkenworthy"
        target="_blank"
        rel="noopener noreferrer"
        class="glass card-hover flex items-center gap-4 p-5 group"
      >
        <div class="w-10 h-10 rounded-lg bg-pink-600/20 border border-pink-600/30 flex items-center justify-center shrink-0">
          <svg class="w-5 h-5 text-pink-400" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-white group-hover:text-pink-400 transition-colors">Instagram</p>
          <p class="text-xs text-surface-200/70">@davidkenworthy</p>
        </div>
        <svg class="w-4 h-4 text-surface-200/50 group-hover:text-surface-200/80 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>

    <!-- Question Form -->
    <div class="max-w-lg">
      <div class="glass p-6">
        <h2 class="text-base font-semibold text-white mb-1">Send me a message</h2>
        <p class="text-sm text-surface-200/80 mb-5">Got a question, idea, or just want to say hi? Fire away.</p>

        <form id="ask-form" class="space-y-4">
          <!-- Honeypot -->
          <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" />
          <!-- Timestamp for spam detection -->
          <input type="hidden" name="ts" id="form-ts" value="" />

          <div>
            <label for="name" class="block text-sm font-medium text-surface-200/80 mb-1">
              Name <span class="text-surface-200/60">(optional)</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              placeholder="Anonymous"
              class="w-full px-4 py-2.5 rounded-lg bg-white/5 border border-white/10 text-white placeholder-white/20 text-sm focus:outline-none focus:border-blue-500/50 focus:ring-1 focus:ring-blue-500/30 transition-colors"
            />
          </div>

          <div>
            <label for="question" class="block text-sm font-medium text-surface-200/80 mb-1">
              Your message
            </label>
            <textarea
              id="question"
              name="question"
              required
              rows="4"
              placeholder="What's on your mind?"
              class="w-full px-4 py-2.5 rounded-lg bg-white/5 border border-white/10 text-white placeholder-white/20 text-sm focus:outline-none focus:border-blue-500/50 focus:ring-1 focus:ring-blue-500/30 transition-colors resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full px-6 py-2.5 rounded-lg bg-blue-500 text-white font-medium text-sm hover:bg-blue-400 transition-colors"
          >
            Send Message
          </button>
        </form>

        <div id="ask-success" class="hidden text-center py-8">
          <p class="text-lg font-medium text-white mb-2">Message sent!</p>
          <p class="text-sm text-surface-200">Thanks for reaching out. I'll get back to you if a reply makes sense.</p>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    // Set timestamp on page load for spam detection
    document.getElementById('form-ts').value = Date.now().toString();

    document.getElementById('ask-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      if (form.website.value) return;

      const btn = form.querySelector('button[type="submit"]');
      const originalText = btn.textContent;
      btn.textContent = 'Sending...';
      btn.disabled = true;

      try {
        const res = await fetch('/api/question', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: form.name.value,
            question: form.question.value,
            website: form.website.value,
            ts: form.ts.value,
          }),
        });

        if (res.ok) {
          form.style.display = 'none';
          document.getElementById('ask-success').classList.remove('hidden');
        } else {
          btn.textContent = 'Failed - try again';
          btn.disabled = false;
          setTimeout(() => { btn.textContent = originalText; }, 2000);
        }
      } catch (err) {
        btn.textContent = 'Failed - try again';
        btn.disabled = false;
        setTimeout(() => { btn.textContent = originalText; }, 2000);
      }
    });
  </script>
</BaseLayout>
