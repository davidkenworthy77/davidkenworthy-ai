---
import BaseLayout from '../../layouts/BaseLayout.astro';
import stackData from '../../content/stack/current.json';

const statusBadge: Record<string, { label: string; class: string }> = {
  new: { label: 'New', class: 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20' },
  changed: { label: 'Changed', class: 'bg-amber-500/10 text-amber-400 border-amber-500/20' },
  dropped: { label: 'Dropped', class: 'bg-red-500/10 text-red-400 border-red-500/20' },
};

const formattedDate = new Date(stackData.date + 'T12:00:00').toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title="The Stack - dk.ai" description="Every tool I actually use, versioned like software.">
  <div class="max-w-3xl mx-auto">
    <div class="mb-10">
      <h1 class="text-3xl font-bold text-white mb-2">The Stack</h1>
      <p class="text-lg text-surface-200">Every tool I actually use, versioned like software.</p>
    </div>

    <!-- Version Banner -->
    <div class="glass p-5 mb-8 flex items-center justify-between">
      <div>
        <span class="font-mono text-lg font-semibold text-amber-400">
          Dave's Stack v{stackData.version}
        </span>
        <span class="text-surface-200/70 text-sm ml-2">/ {formattedDate}</span>
      </div>
      <a href="/stack/changelog" class="text-sm text-accent-DEFAULT hover:text-accent-hover transition-colors">
        View changelog &rarr;
      </a>
    </div>

    <!-- Categories -->
    <div class="space-y-8">
      {stackData.categories.map((category) => (
        <div>
          <h2 class="text-sm font-semibold text-white/70 uppercase tracking-wider mb-4 flex items-center gap-2">
            {category.name}
            <span class="flex-1 h-px bg-white/5"></span>
          </h2>
          <div class="space-y-2">
            {category.tools.map((tool) => (
              <div class="glass p-4 flex items-start justify-between gap-4">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1">
                    <a
                      href={tool.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="font-medium text-white hover:text-accent-DEFAULT transition-colors"
                    >
                      {tool.name}
                    </a>
                    {tool.status !== 'unchanged' && statusBadge[tool.status] && (
                      <span class:list={['badge border text-[10px]', statusBadge[tool.status].class]}>
                        {statusBadge[tool.status].label}
                      </span>
                    )}
                  </div>
                  <p class="text-sm text-surface-200">{tool.verdict}</p>
                </div>
                <a
                  href={tool.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="shrink-0 text-surface-200/50 hover:text-surface-200/80 transition-colors"
                >
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
