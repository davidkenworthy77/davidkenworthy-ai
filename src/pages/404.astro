---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - dk.ai">
  <div class="flex flex-col items-center justify-center min-h-[50vh] text-center">
    <p class="font-mono text-6xl font-bold text-accent-DEFAULT mb-4">404</p>
    <h1 class="text-2xl font-bold text-white mb-3">This page doesn't exist yet.</h1>
    <p class="text-surface-200 mb-8 max-w-md">
      Maybe it should. <a href="/ask" class="text-accent-DEFAULT hover:text-accent-hover transition-colors">Ask me about it.</a>
    </p>
    <a href="/" class="px-6 py-2.5 rounded-lg bg-accent-DEFAULT text-white font-medium text-sm hover:bg-accent-hover transition-colors">
      Go home
    </a>
  </div>
</BaseLayout>
