---
interface Props {
  variant?: 'blue' | 'amber';
}

const { variant = 'blue' } = Astro.props;
const isAmber = variant === 'amber';
const bg = isAmber ? 'rgba(245,158,11,0.05)' : 'rgba(59,130,246,0.05)';
const border = isAmber ? 'rgba(245,158,11,0.15)' : 'rgba(59,130,246,0.15)';
---

<div class="not-prose" style={`background: ${bg}; border: 1px solid ${border}; border-radius: 0.75rem; padding: 1.25rem; margin-top: 2rem; margin-bottom: 2rem;`}>
  <p style="font-size: 0.9375rem; color: var(--text-secondary); line-height: 1.625;">
    <slot />
  </p>
</div>
