---
interface Props {
  title: string;
  href: string;
  date: Date;
  type: 'long-read' | 'daily' | 'lab' | 'stack';
  excerpt?: string;
  readingTime?: number;
  tags?: string[];
  status?: string;
  subtype?: string;
  heroImage?: string;
}

const { title, href, date, type, excerpt, readingTime, tags, status, subtype, heroImage } = Astro.props;

const typeLabels: Record<string, string> = {
  'long-read': 'Long Read',
  daily: 'Daily',
  lab: 'Lab',
  stack: 'Stack',
};

const badgeClass: Record<string, string> = {
  'long-read': 'badge-long-reads',
  daily: 'badge-daily',
  lab: 'badge-lab',
  stack: 'badge-stack',
};

const subtypeLabels: Record<string, string> = {
  'quick-thought': 'Thought',
  link: 'Link',
  quote: 'Quote',
  til: 'TIL',
  question: 'Question',
};

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={href} class="glass card-hover block overflow-hidden group">
  {heroImage && (
    <div class="w-full h-40 overflow-hidden">
      <img
        src={heroImage}
        alt=""
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    </div>
  )}
  <div class="p-5">
    <div class="flex items-center gap-2 mb-3">
      <span class:list={['badge', badgeClass[type]]}>
        {typeLabels[type]}
      </span>
      {subtype && (
        <span class="badge bg-white/5 text-surface-200 border border-white/5">
          {subtypeLabels[subtype] || subtype}
        </span>
      )}
      {status && status !== 'published' && (
        <span class="badge bg-amber-500/10 text-amber-400 border border-amber-500/20">
          {status}
        </span>
      )}
    </div>

    <h3 class="text-base font-semibold text-white group-hover:text-accent-DEFAULT transition-colors mb-2">
      {title}
    </h3>

    {excerpt && (
      <p class="text-sm text-surface-200 line-clamp-2 mb-3">{excerpt}</p>
    )}

    <div class="flex items-center gap-3 text-xs text-surface-200/70 font-mono">
      <span class="inline-flex items-center gap-1">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </span>
      {readingTime && (
        <span class="inline-flex items-center gap-1">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          {readingTime} min read
        </span>
      )}
      {type !== 'long-read' && tags && tags.length > 0 && (
        <div class="flex gap-1.5">
          {tags.slice(0, 3).map((tag) => (
            <span class="text-accent-DEFAULT/60">#{tag}</span>
          ))}
        </div>
      )}
    </div>
  </div>
</a>
